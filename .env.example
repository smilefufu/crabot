# Crabot 环境变量配置

# Admin 模块配置
CRABOT_ADMIN_PASSWORD=your_admin_password_here
CRABOT_JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# crabot-admin 加密密钥（用于加密存储用户的 API Key）
ADMIN_ENCRYPTION_KEY=your-encryption-key-here

# Admin 模块端口（由 Module Manager 分配，通常不需要手动设置）
# CRABOT_ADMIN_PORT=19001
# CRABOT_ADMIN_WEB_PORT=3000

# 注意：AI 提供商的 API Key 不再在这里配置
# 用户通过 Admin WebUI 配置模型供应商时输入